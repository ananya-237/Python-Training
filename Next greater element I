nums1 = [4,1,2]
nums2 = [1,3,4,2]
stack = []
hp = {}
size = -(len(nums2))
index = -1
while(size <= index):
    data = nums2[index]
    while stack:
        if stack[-1] > data:
            hp[data] = stack[-1]
            break
        else:
            stack.pop()
    if not stack:
        hp[data]  = -1
    stack.append(data)
    index -= 1
ans = []
for val in nums1:
    ans.append(hp[val])
print(ans)  